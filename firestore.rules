rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Config (e.g. activeTripId) — public read, admin write
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Trips — public read, admin write
    match /trips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Scores — public read, admin write
    match /scores/{scoreId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
